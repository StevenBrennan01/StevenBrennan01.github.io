---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
		<section class="sb-hero">
			<div class="sb-heroRow">
			<img class="sb-avatar" src="/me.png" alt="Portrait of Steven Brennan" width="160" height="160" />
			<div>
				<h1 class="sb-name">Steven Brennan</h1>
				<h2 class="sb-role">Junior Gameplay Programmer</h2>
			</div>
			</div>
		</section>

		<p>My name is …</p>
		...
		</main>

		<style>
		.sb-heroRow {
			display: flex;
			align-items: center;
			gap: 1rem;
			margin-top: 1.5rem;
		}

		/* This is the key anti-float / anti-weird-flow guard */
		.sb-avatar {
			display: block;
			float: none;
			width: 160px;
			height: 160px;
			object-fit: cover;
			flex: 0 0 auto;
		}

		.sb-name { margin: 0; }
		.sb-role {
			margin: 0.25rem 0 0 0;
			opacity: 0.85;
			font-weight: 500;
		}
		</style>
		<Footer />
	</body>
</html>