---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="sb-hero" aria-labelledby="sb-hero-title">
			<video
				class="sb-heroVideo"
				autoplay
				muted
				loop
				playsinline
				preload="metadata"
				aria-hidden="true"
			>
				<source src="/TankPlaceholder.mp4" type="video/mp4" />
			</video>

			<div class="sb-heroOverlay" aria-hidden="true"></div>

			<div class="sb-heroContent">
				<img class="sb-avatar" src="/me.png" alt="Portrait of Steven Brennan" width="240" height="240" />
				<div>
				<h1 id="sb-hero-title" class="sb-name">Steven Brennan</h1>
				<h2 class="sb-role">BSc (Hons) Games Design and Programming Student</h2>
				</div>
			</div>
			</section>
			<p> 
				Hi, I'm <strong><a href="https://www.linkedin.com/in/steven-brennan-37b473234/" target="_blank" rel="noopener noreferrer">Steve</a></strong>, a recent graduate from the University of Staffordshire for Games Design and Programming. I primarily work within the Unity engine using C#, with additional experience including Unreal (Blueprints), C++ using the SFML library and I'm currently exploring and learning within the S&box engine (Facepunch) through personal projects.
			</p>
			<p>
				I am <strong>actively</strong> seeking junior gameplay programming roles (or adjacent positions), and open to relocation. Feel free to check out some of my <a href="https://stevenbrennandev.com/projects/" target="_blank" rel="noopener noreferrer">projects</a> both University and Personal. Thanks for taking a look!
			</p>
			<ul>
				<li>✅ <strong>Astro v6</strong> - Built with the latest Astro features</li>
				<li>✅ <strong>Dark Mode</strong> - Toggle between light and dark themes</li>
				<li>✅ <strong>Tag System</strong> - Organize posts by tags with dedicated tag pages</li>
				<li>✅ <strong>Responsive Design</strong> - Mobile-first with hamburger navigation</li>
				<li>✅ <strong>Content Collections</strong> - Type-safe blog posts with Zod validation</li>
				<li>✅ <strong>SEO Optimized</strong> - Canonical URLs, OpenGraph data, and sitemap</li>
				<li>✅ <strong>RSS Feed</strong> - Auto-generated RSS feed for subscribers</li>
				<li>✅ <strong>MDX Support</strong> - Enhanced markdown with component support</li>
				<li>✅ <strong>Breadcrumb Navigation</strong> - Clear navigation paths</li>
				<li>✅ <strong>Performance</strong> - Optimized images with Sharp</li>
				<li>✅ <strong>Minimal Styling</strong> - Clean design based on Astro Starter Kit: Blog</li>
				<li>✅ <strong>Atkinson Hyperlegible Fonts</strong> - Local variable fonts optimized for readability</li>
				<li>✅ <strong>Accessible</strong> - WCAG 2.2 AA compliant with keyboard navigation and screen reader support</li>
			</ul>

			<p>I started building this theme for my personal blog but it's now open source. Customize it, make it yours, and start sharing your ideas with the world. Happy blogging! ✨</p>
			</main>

			<style>
			/* Hero container */
			.sb-hero {
			position: relative;
			overflow: hidden;

			margin-top: 1.5rem;
			padding: 2rem 1.5rem;
			border-radius: 16px;

			/* Optional: gives it a subtle card feel */
			border: 2px solid var(--border-color);
			background: var(--content-bg, transparent);

			min-height: 320px;
			}

			/* Background video */
			.sb-heroVideo {
			position: absolute;
			inset: 0;

			width: 100%;
			height: 100%;
			object-fit: cover;

			/* The “blurred background” effect */
			filter: blur(9px) brightness(0.65) saturate(1.15);
			transform: scale(1.08); /* avoids blurred edges showing */
			}

			/* Dark overlay for readability (tune opacity to taste) */
			.sb-heroOverlay {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				90deg,
				rgba(0, 0, 0, 0.65),
				rgba(0, 0, 0, 0.25)
			);
			}

			/* Foreground content */
			.sb-heroContent {
			position: relative;
			z-index: 1;

			display: flex;
			align-items: center;
			gap: 1rem;
			}

			/* Avatar */
			.sb-avatar {
			display: block;
			float: none;

			width: 240px;
			height: 240px;
			object-fit: cover;
			flex: 0 0 auto;
			}

			/* Text */
			.sb-name {
			margin: 0;
			}

			.sb-role {
			margin: 0.25rem 0 0 0;
			opacity: 0.9;
			font-weight: 500;
			}

			/* Mobile layout: stack nicely */
			@media (max-width: 720px) {
			.sb-hero {
				padding: 1.5rem 1rem;
				min-height: 360px;
			}

			.sb-heroContent {
				flex-direction: column;
				align-items: flex-start;
			}

			.sb-avatar {
				width: 160px;
				height: 160px;
			}
			}
			</style>

		<Footer />
	</body>
</html>