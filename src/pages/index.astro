---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="sb-hero" aria-labelledby="sb-hero-title">
			<video
				class="sb-heroVideo"
				poster="/poster.png"
				autoplay
				muted
				loop
				playsinline
				preload="none"
				aria-hidden="true"
			>
				<source src="/TankPlaceholder.mp4" type="video/mp4" />
			</video>

			<div class="sb-heroOverlay" aria-hidden="true"></div>

			<div class="sb-heroContent">
				<img class="sb-avatar" src="/me.png" alt="Portrait of Steven Brennan" width="240" height="240" />
				<div>
				<h1 id="sb-hero-title" class="sb-name">Steven Brennan</h1>
				<h2 class="sb-role">BSc (Hons) Games Design and Programming Student</h2>
				</div>
			</div>
			</section>
			<p> 
				Hi, I'm <strong><a href="https://www.linkedin.com/in/steven-brennan-37b473234/" target="_blank" rel="noopener noreferrer">Steve</a></strong>, a recent graduate from the University of Staffordshire for Games Design and Programming. I primarily work within the Unity engine using C#, with additional experience including Unreal (Blueprints), C++ using the SFML library and I'm currently exploring and learning within the S&box engine (Facepunch) through personal projects.
			</p>

			<section class="sb-showreel" aria-label="Showreel">

			<div class="sb-videoWrap">
				<iframe
				class="sb-video"
				src="https://www.youtube.com/embed/nI0zW5LBLMM?autoplay=1&mute=1&controls=1&rel=0&modestbranding=1&playsinline=1"
				title="Steven Brennan - Showreel"
				frameborder="0"
				allow="autoplay; encrypted-media; picture-in-picture"
				allowfullscreen
				></iframe>
			</div>
			</section>

			<h1>Skills and Tools</h1>
			</main>

			<style>
			/* Hero container */
			.sb-hero {
			position: relative;
			overflow: hidden;

			margin-top: 1.25rem;
			padding: 2rem 1.5rem;
			border-radius: 16px;

			/* Optional: gives it a subtle card feel */
			border: 2px solid var(--border-color);
			background: var(--content-bg, transparent);

			width: min(1000px, calc(100vw - 2rem));
			left: 50%;
			transform: translateX(-50%);
			min-height: 225px;
			}

			/* Background video */
			.sb-heroVideo {
			position: absolute;
			inset: 0;

			width: 100%;
			height: 100%;
			object-fit: cover;

			/* The “blurred background” effect */
			filter: blur(4px) brightness(0.65) saturate(1.15);
			transform: scale(1.08); /* avoids blurred edges showing */
			}

			/* Dark overlay for readability (tune opacity to taste) */
			.sb-heroOverlay {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				90deg,
				rgba(0, 0, 0, 0.65),
				rgba(0, 0, 0, 0.25)
			);
			}

			/* Foreground content */
			.sb-heroContent {
			position: relative;
			z-index: 1;

			display: flex;
			align-items: center;
			gap: 1rem;
			}

			/* Avatar */
			.sb-avatar {
			display: block;
			float: none;

			width: 240px;
			height: 240px;
			object-fit: cover;
			flex: 0 0 auto;
			}

			/* Text */
			.sb-name {
			margin: 0;
			}

			.sb-role {
			margin: 0.25rem 0 0 0;
			opacity: 0.9;
			font-weight: 500;
			}

			/* Mobile layout: stack nicely */
			@media (max-width: 720px) {
			.sb-hero {
				padding: 1.5rem 1rem;
				min-height: 360px;
			}

			.sb-heroContent {
				flex-direction: column;
				align-items: flex-start;
			}

			.sb-avatar {
				width: 160px;
				height: 160px;
			}
			}

			.sb-showreel {
			margin-top: 2rem;
			}

			.sb-videoWrap {
			position: relative;
			width: 100%;
			aspect-ratio: 16 / 9;
			border-radius: 16px;
			overflow: hidden;
			border: 1px solid var(--border-color);
			background: #000;
			}

			.sb-video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			}

			</style>

		<Footer />
	</body>
</html>